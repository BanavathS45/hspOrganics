rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Products: Anyone can read, only authenticated admin users can add/update/delete
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Orders: Authenticated users can read/write their own orders; admin can read/write all
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    // 3. Addresses: Authenticated users can manage their own addresses
    match /addresses/{addressId} {
      allow read, write: if request.auth != null;
    }

    // 4. Notifications: Read/write permitted to dispatch notifications and updates
    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    // 5. Wishlist: Authenticated users can manage their own wishlist
    match /wishlist/{wishlistId} {
      allow read, write: if request.auth != null;
    }

    // 6. Coupons: Anyone can read coupons; admin can write/modify coupons
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
